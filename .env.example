##############################################################################
# Stock Research Platform — Environment Variables
# Copy this file to .env and fill in your values.
##############################################################################

# ── LLM Provider ──────────────────────────────────────────────────────────
# Default: groq (open-source Llama-3.3-70B — free, fast, strong reasoning)
# Alternative: openai
LLM_PROVIDER=groq

# Groq API key — free tier at https://console.groq.com
# Model: llama-3.3-70b-versatile (≈ GPT-4o quality, much faster than gpt-4o-mini)
GROQ_API_KEY=

# OpenAI fallback (used if GROQ_API_KEY is empty or LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Data providers ────────────────────────────────────────────────────────
# Finnhub: real-time quotes + company news — free at https://finnhub.io
FINNHUB_API_KEY=

# Financial Modeling Prep: fundamentals (P/E, EPS, beta) — https://financialmodelingprep.com
FMP_API_KEY=

# Optional extras
ALPHA_VANTAGE_KEY=
POLYGON_API_KEY=
NEWS_API_KEY=

# ── Infrastructure (defaults match docker-compose.yml) ────────────────────
DATABASE_URL=postgresql+asyncpg://srp:srp@postgres:5432/srp
REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
