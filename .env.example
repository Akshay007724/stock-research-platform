##############################################################################
# Stock Research Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Only OPENAI_API_KEY is strictly required.
##############################################################################

# ── Required ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional data enrichment ──────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key

FINNHUB_API_KEY=d6u5ao9r01qp1k9bab50d6u5ao9r01qp1k9bab5g
FMP_API_KEY=XnAMGf50JQNvMV6MFfJ6AX8Q0EcA69Sh
# Polygon.io: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=

# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# ── Infrastructure (default values work with docker-compose.yml) ──────────
DATABASE_URL=postgresql+asyncpg://srp:srp@postgres:5432/srp
REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant

# ── Model selection ───────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
